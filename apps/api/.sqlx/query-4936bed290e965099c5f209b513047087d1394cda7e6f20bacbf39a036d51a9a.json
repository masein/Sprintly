{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT c.id            AS \"id!: Uuid\",\n               c.task_id       AS \"task_id!: Uuid\",\n               c.author_id,\n               u.handle        AS \"author_handle?: String\",\n               u.avatar_url    AS \"author_avatar_url?: String\",\n               u.avatar_style  AS \"author_avatar_style?: String\",\n               u.avatar_seed   AS \"author_avatar_seed?: String\",\n               c.parent_comment_id,\n               c.body          AS \"body!: String\",\n               c.created_at    AS \"created_at!: DateTime<Utc>\",\n               c.edited_at\n        FROM   task_comments c\n        LEFT JOIN users u ON u.id = c.author_id\n        WHERE  c.id = $1 AND c.deleted_at IS NULL\n        ",
