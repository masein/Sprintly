  "query": "\n        SELECT key          AS \"key!: String\",\n               title        AS \"title!: String\",\n               status       AS \"status!: String\",\n               priority     AS \"priority!: String\",\n               type         AS \"type!: String\",\n               story_points,\n               assignee_id\n        FROM   tasks\n        WHERE  sprint_id = $1 AND deleted_at IS NULL\n        ORDER  BY status, priority, updated_at DESC\n        ",
