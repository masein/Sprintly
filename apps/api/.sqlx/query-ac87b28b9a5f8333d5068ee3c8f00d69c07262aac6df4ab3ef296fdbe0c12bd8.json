{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id              AS \"id!: Uuid\",\n               project_id      AS \"project_id!: Uuid\",\n               url             AS \"url!: String\",\n               events          AS \"events!: Vec<String>\",\n               active          AS \"active!: bool\",\n               last_delivery_at,\n               last_status,\n               created_at      AS \"created_at!: DateTime<Utc>\"\n        FROM   webhooks\n        WHERE  project_id = $1 AND deleted_at IS NULL\n        ORDER  BY created_at DESC\n        ",
