# ─────────────────────────────────────────────────────────────────────────────
# Sprintly — environment template.
# Copy to `.env` and fill in. `.env` is gitignored. Anything secret-ish must
# stay in `.env`. `.env.example` is checked in and only contains placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
SPRINTLY_ENV=dev                       # dev | prod
SPRINTLY_PUBLIC_URL=http://localhost:8080
SPRINTLY_API_BIND=0.0.0.0:8081
RUST_LOG=info,sprintly_api=debug,sqlx=warn,tower_http=info

# Allow public registration. After the first registered user, set this to false
# and use invite tokens for all subsequent users (admin-generated, in-app).
SPRINTLY_OPEN_SIGNUP=true

# --- Postgres ---
POSTGRES_USER=sprintly
POSTGRES_PASSWORD=sprintly_dev_pw_change_me
POSTGRES_DB=sprintly
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://sprintly:sprintly_dev_pw_change_me@postgres:5432/sprintly

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=sprintly
MINIO_ROOT_PASSWORD=sprintly_dev_pw_change_me
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=sprintly
MINIO_REGION=us-east-1

# --- Auth ---
# 64 random bytes, base64. Used to sign access tokens (HS256).
# Generate: `openssl rand -base64 64 | tr -d '\n'`
SPRINTLY_JWT_SECRET=replace-me-with-64-bytes-of-base64-noise

# Access token TTL (seconds) and refresh token TTL (seconds).
SPRINTLY_ACCESS_TTL_SECS=900
SPRINTLY_REFRESH_TTL_SECS=2592000

# Argon2id parameters. Tune so login takes ~250ms on prod hardware.
SPRINTLY_ARGON2_M_COST_KIB=65536
SPRINTLY_ARGON2_T_COST=3
SPRINTLY_ARGON2_P_COST=1

# Auth rate limits (Redis fixed-window). Defaults shown; raise/lower as needed.
# Login is throttled per source IP and per email (per minute); password-reset
# requests per IP and per email (per hour). Over the limit → HTTP 429.
SPRINTLY_RL_LOGIN_IP_PER_MIN=20
SPRINTLY_RL_LOGIN_EMAIL_PER_MIN=8
SPRINTLY_RL_RESET_IP_PER_HOUR=10
SPRINTLY_RL_RESET_EMAIL_PER_HOUR=5

# --- Email (transactional: password reset, invites) ---
# Leave SPRINTLY_SMTP_URL unset to log outbound mail instead of sending it
# (the dev default). To actually send, point it at an SMTP server, e.g.:
#   smtps://user:pass@smtp.example.com:465      (implicit TLS)
#   smtp://user:pass@smtp.example.com:587        (STARTTLS)
# SPRINTLY_SMTP_URL=
SPRINTLY_MAIL_FROM=Sprintly <noreply@localhost>

# --- Git integration (inbound GitHub webhooks) ---
# Set this to the secret you configure on the GitHub repo webhook to enable
# /integrations/github/webhook. Sprintly then links commits/PRs whose message
# or title references a task key (e.g. DEMO-1) to that task, with activity-feed
# entries. Leave unset to disable the endpoint.
# SPRINTLY_GITHUB_WEBHOOK_SECRET=

# --- Vault crypto ---
# 32 random bytes, base64. App refuses to boot without it.
# Generate: `openssl rand -base64 32 | tr -d '\n'`
SPRINTLY_VAULT_MASTER_KEY=replace-me-with-32-bytes-of-base64-noise
SPRINTLY_VAULT_KEY_VERSION=1

# --- Web (Next.js) ---
# Public vars must be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_APP_NAME=Sprintly

# --- Caddy ---
# In prod, set this to your real domain and Caddy will auto-TLS via Let's Encrypt.
CADDY_DOMAIN=localhost
CADDY_EMAIL=admin@localhost
