{
  "name": "sprintly",
  "private": true,
  "version": "1.0.0",
  "description": "Sprintly — self-hosted dev-themed PM. Root workspace.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @sprintly/web dev",
    "build": "pnpm --filter @sprintly/web build",
    "lint": "pnpm --filter @sprintly/web lint",
    "format": "pnpm --filter @sprintly/web format",
    "typecheck": "pnpm --filter @sprintly/web typecheck",
    "e2e": "pnpm --filter @sprintly/e2e test",
    "e2e:install": "pnpm --filter @sprintly/e2e install-browsers"
  }
}
